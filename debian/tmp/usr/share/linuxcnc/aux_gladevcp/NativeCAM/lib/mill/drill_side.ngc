o<drill_side> sub
(Horizontal side drilling  version 6)
(CALL: side, pos, depth, z_hole, clearance, wp_front, wp_rear, wp_left, wp_right)
(  #1 = side      0=Top  1=Bottom  2=Left  3=Right)
(  #2 = pos       X for Top/Bottom, Y for Left/Right)
(  #3 = depth     distance drill enters workpiece)
(  #4 = z_hole    Z height of hole center)
(  #5 = clearance safe distance outside face before feed)
(  #6 = wp_front  Y coordinate of front face)
(  #7 = wp_rear   Y coordinate of rear face)
(  #8 = wp_left   X coordinate of left face)
(  #9 = wp_right  X coordinate of right face)

	(raise to safe Z before any XY movement)
	o<sz> if [#<_z> LT #<_rapid_z>]
		G0 Z#<_rapid_z>
	o<sz> endif

	o<top> if [#1 EQ 0]
		(TOP: pos=X coord, approach outside front face at Y minus clearance, feed Y+)
		G0 X#2 Y[#6 - #5]
		G0 Z#4
		G1 Y[#6 + #3] F#<_drill_feed>
		G0 Y[#6 - #5]
		G0 Z#<_rapid_z>
	o<top> endif

	o<bot> if [#1 EQ 1]
		(BOTTOM: pos=X coord, approach outside rear face at Y plus clearance, feed Y-)
		G0 X#2 Y[#7 + #5]
		G0 Z#4
		G1 Y[#7 - #3] F#<_drill_feed>
		G0 Y[#7 + #5]
		G0 Z#<_rapid_z>
	o<bot> endif

	o<lft> if [#1 EQ 2]
		(LEFT: pos=Y coord, approach outside left face at X minus clearance, feed X+)
		(approach: X = wp_left - clearance,  drill to: X = wp_left + depth)
		G0 Y#2 X[#8 - #5]
		G0 Z#4
		G1 X[#8 + #3] F#<_drill_feed>
		G0 X[#8 - #5]
		G0 Z#<_rapid_z>
	o<lft> endif

	o<rgt> if [#1 EQ 3]
		(RIGHT: pos=Y coord, approach outside right face at X plus clearance, feed X-)
		(approach: X = wp_right + clearance, drill to: X = wp_right - depth)
		G0 Y#2 X[#9 + #5]
		G0 Z#4
		G1 X[#9 - #3] F#<_drill_feed>
		G0 X[#9 + #5]
		G0 Z#<_rapid_z>
	o<rgt> endif

o<drill_side> endsub
